{
  "name": "llm-router",
  "version": "1.0.0",
  "description": "A resilient gateway in front of multiple LLM providers — automatic fallback, retries with backoff, circuit breaking, and per-call cost tracking. Zero runtime dependencies.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "keywords": [
    "llm",
    "ai",
    "openai",
    "anthropic",
    "openrouter",
    "gateway",
    "router",
    "fallback",
    "resilience",
    "cost-tracking"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
